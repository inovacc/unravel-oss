# Line-ending normalization.
# Go tooling (gofmt) emits LF; without this, Windows checkouts drift to CRLF
# and every edited file shows as fully rewritten. Enforce LF for source and
# config; keep CRLF for Windows-only scripts.

* text=auto

# Source / config — always LF
*.go      text eol=lf
*.sh      text eol=lf
*.mod     text eol=lf
*.sum     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.sql     text eol=lf
*.proto   text eol=lf

# Windows-only scripts — always CRLF
*.ps1     text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary assets — never normalize
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.tar     binary
*.exe     binary
*.dll     binary
*.so      binary
*.dylib   binary
*.wasm    binary
*.asar    binary
