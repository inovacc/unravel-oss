<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
         xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
         xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
         xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
         xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10">
  <Identity Name="FullExt" Version="1.0.0.0" Publisher="CN=Test" ProcessorArchitecture="x64"/>
  <Properties>
    <DisplayName>Full Extensions App</DisplayName>
    <Description>Fixture covering all extension categories (D-69-03)</Description>
    <PublisherDisplayName>Test Publisher</PublisherDisplayName>
  </Properties>
  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0"/>
  </Dependencies>
  <Applications>
    <Application Id="App" Executable="app.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="Full Extensions App"
                          Description="A test app"
                          BackgroundColor="#0078D4"
                          Square150x150Logo="Assets/Square150.png"
                          Square44x44Logo="Assets/Square44.png"/>
      <Extensions>
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="whatsapp"/>
        </uap:Extension>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="foofiles">
            <uap:SupportedFileTypes>
              <uap:FileType>.foo</uap:FileType>
              <uap:FileType>.bar</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
        <uap:Extension Category="windows.shareTarget">
          <uap:ShareTarget>
            <uap:SupportedFileTypes>
              <uap:SupportedType>text/plain</uap:SupportedType>
              <uap:SupportedType>image/png</uap:SupportedType>
            </uap:SupportedFileTypes>
          </uap:ShareTarget>
        </uap:Extension>
        <Extension Category="windows.backgroundTasks" EntryPoint="App.Background">
          <BackgroundTasks>
            <Task Type="systemEvent"/>
            <Task Type="timer"/>
          </BackgroundTasks>
        </Extension>
        <uap:Extension Category="windows.appService" EntryPoint="App.Svc">
          <uap:AppService Name="org.example.svc"/>
        </uap:Extension>
        <Extension Category="windows.activatableClass.inProcessServer">
          <InProcessServer>
            <Path>x.dll</Path>
            <ActivatableClass ActivatableClassId="App.Foo" ThreadingModel="both"/>
            <ActivatableClass ActivatableClassId="App.Bar" ThreadingModel="both"/>
          </InProcessServer>
        </Extension>
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:ExeServer Executable="app.exe">
              <com:Class Id="{11111111-1111-1111-1111-111111111111}" DisplayName="C1"/>
            </com:ExeServer>
          </com:ComServer>
        </com:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
