<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8">
<title>Forensic Report - {{.Report.AppName}}</title>
<style>
:root {
  --severity-block: #b00; --severity-block-bg: #fee;
  --severity-flag: #b80;  --severity-flag-bg: #ffd;
  --severity-pass: #060;  --severity-pass-bg: #efe;
}
body { font: 14px -apple-system, system-ui, sans-serif; max-width: 900px; margin: 2em auto; color: #222; }
h1, h2 { border-bottom: 1px solid #ccc; padding-bottom: 0.2em; }
.badge-block { color: var(--severity-block); background: var(--severity-block-bg); padding: 2px 6px; border-radius: 3px; font-weight: bold; }
.badge-flag  { color: var(--severity-flag);  background: var(--severity-flag-bg);  padding: 2px 6px; border-radius: 3px; font-weight: bold; }
.badge-pass  { color: var(--severity-pass);  background: var(--severity-pass-bg);  padding: 2px 6px; border-radius: 3px; font-weight: bold; }
.badge-info  { color: #036; background: #eef; padding: 2px 6px; border-radius: 3px; font-weight: bold; }
table.risk-matrix { border-collapse: collapse; }
table.risk-matrix td, table.risk-matrix th { border: 1px solid #888; padding: 8px 12px; min-width: 80px; text-align: center; }
pre.curl { background: #f4f4f4; padding: 1em; overflow-x: auto; font-size: 12px; }
img.screenshot { max-width: 100%; border: 1px solid #ccc; }
.tldr { font-size: 1.1em; line-height: 1.5; }
</style></head><body>
<h1>Forensic Report: {{.Report.AppName}}</h1>

<section aria-label="Executive Summary"><h2>Executive Summary</h2>
{{if .Options.ExecSummary}}
<p class="tldr">{{.Options.ExecSummary.TLDR}}</p>
<h3>Top Risks</h3><ol>{{range .Options.ExecSummary.TopRisks}}<li><span class="{{badgeClass .Severity}}">[{{.Severity}}]</span> {{.Title}}{{if .CWE}} (<a href="{{cweLink .CWE}}">CWE-{{.CWE}}</a>){{end}}</li>{{end}}</ol>
<h3>Remediation Priorities</h3><ol>{{range .Options.ExecSummary.RemediationPriorities}}<li>{{.}}</li>{{end}}</ol>
{{else}}<p><em>Run with <code>--ai</code> for an MCP-generated executive summary.</em></p>{{end}}
</section>

<section aria-label="Risk Matrix"><h2>Risk Matrix</h2>
<table class="risk-matrix" role="table"><caption>3x3 likelihood vs impact (ISO 27005 / OWASP)</caption>
<tr><th></th><th>Low Impact</th><th>Med Impact</th><th>High Impact</th></tr>
<tr><th>High Likelihood</th><td>L3I1</td><td>L3I2</td><td>L3I3</td></tr>
<tr><th>Med Likelihood</th><td>L2I1</td><td>L2I2</td><td>L2I3</td></tr>
<tr><th>Low Likelihood</th><td>L1I1</td><td>L1I2</td><td>L1I3</td></tr>
</table></section>

<section aria-label="Findings"><h2>Findings</h2>
{{range $i, $f := .Report.Findings}}
<div id="finding-{{$i}}"><h3><span class="{{badgeClass $f.Severity}}" aria-label="severity {{$f.Severity}}">[{{$f.Severity}}]</span> {{$f.Title}}</h3>
<p>{{$f.Description}}</p>
{{if cweN $f.Category}}<p>CWE: <a href="{{cweLink (cweN $f.Category)}}">CWE-{{cweN $f.Category}}</a></p>{{end}}
</div>{{end}}
</section>

<section aria-label="Replay Reproducibility"><h2>Replay Reproducibility</h2>
{{range $j, $c := .Report.CurlScripts}}<h3 id="replay-{{$j}}">{{$c.Name}}</h3><pre class="curl">{{$c.Command}}</pre>{{end}}
</section>

{{if .Screenshots}}<section aria-label="Visual Capture"><h2>Visual Capture</h2>
{{range .Screenshots}}<img class="screenshot" src="{{base64Image .}}" alt="captured screenshot">{{end}}
</section>{{end}}

<section aria-label="CWE Mappings"><h2>CWE Mappings</h2><ul>
{{range .Report.Findings}}{{if cweN .Category}}<li>{{.Title}} -&gt; <a href="{{cweLink (cweN .Category)}}">CWE-{{cweN .Category}}</a></li>{{end}}{{end}}
</ul></section>

{{if .Options.Regression}}<section aria-label="Regression Analysis"><h2>Regression Analysis</h2>{{.Options.Regression.HTML}}</section>{{end}}

</body></html>
