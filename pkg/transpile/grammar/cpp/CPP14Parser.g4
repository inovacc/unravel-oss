// CPP14 Parser Grammar
// Download the full grammar from: https://github.com/antlr/grammars-v4/tree/master/cpp
// This is a placeholder. Run `task generate:grammar` after placing the full grammar here.
parser grammar CPP14Parser;

options { tokenVocab = CPP14Lexer; }

// Placeholder - replace with full CPP14 parser grammar from antlr/grammars-v4
translationUnit: EOF;
